{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MasterIndex",
  "type": "object",
  "required": ["index"],
  "properties": {
    "index": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "family",
          "sector",
          "stage",
          "element",
          "file"
        ],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "family": { "type": "string" },
          "sector": { "type": "string" },
          "stage": { "type": "string" },
          "element": {
            "type": "string",
            "enum": [
              "core",
              "root",
              "pulse",
              "archive",
              "cloud",
              "firewall",
              "dream",
              "echo",
              "void",
              "corrupt"
            ]
          },
          "file": { "type": "string" }
        },
        "additionalProperties": false
      }
    },

    "core": {
      "type": "array",
      "items": { "type": "string" }
    },
    "root": {
      "type": "array",
      "items": { "type": "string" }
    },
    "pulse": {
      "type": "array",
      "items": { "type": "string" }
    },
    "archive": {
      "type": "array",
      "items": { "type": "string" }
    },
    "cloud": {
      "type": "array",
      "items": { "type": "string" }
    },
    "firewall": {
      "type": "array",
      "items": { "type": "string" }
    },
    "dream": {
      "type": "array",
      "items": { "type": "string" }
    },
    "echo": {
      "type": "array",
      "items": { "type": "string" }
    },
    "void": {
      "type": "array",
      "items": { "type": "string" }
    },
    "corrupt": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
