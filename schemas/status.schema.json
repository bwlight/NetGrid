{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "StatusEffect",
  "type": "object",
  "properties": {
    "status": {
      "type": "object",
      "required": [
        "id",
        "name",
        "type",
        "duration_type",
        "duration",
        "stackable",
        "effects",
        "description"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9_\\.]+$"
        },
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "buff",
            "debuff",
            "control",
            "damage_over_time",
            "special"
          ]
        },
        "duration_type": {
          "type": "string",
          "enum": [
            "turns",
            "permanent",
            "conditional"
          ]
        },
        "duration": {
          "type": "integer",
          "minimum": 0
        },
        "stackable": {
          "type": "boolean"
        },
        "effects": {
          "type": "object",
          "description": "Key-value pairs defining mechanical effects.",
          "additionalProperties": {
            "type": [
              "integer",
              "number",
              "boolean",
              "string",
              "array"
            ]
          }
        },
        "description": {
          "type": "string"
        }
      }
    }
  },
  "required": ["status"]
}
