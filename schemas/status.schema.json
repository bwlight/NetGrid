{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Status",
  "type": "object",
  "required": ["id", "name", "category", "tags"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "category": {
      "type": "string",
      "enum": ["major", "minor", "field", "buff", "debuff"]
    },
    "duration": {
      "type": ["integer", "string", "null"],
      "description": "Turns or 'permanent'"
    },
    "stack_limit": { "type": ["integer", "null"], "minimum": 1 },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "effects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": { "type": "string" },
          "value": {},
          "timing": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
