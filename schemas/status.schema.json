{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Status Effect Schema",
  "type": "object",

  "properties": {
    "$schema": {
      "type": "string",
      "description": "VS Code schema reference (ignored by game logic)"
    },

    "status": {
      "type": "object",

      "properties": {
        "id": {
          "type": "string",
          "description": "Unique status identifier"
        },

        "name": {
          "type": "string",
          "description": "Display name of the status effect"
        },

        "duration": {
          "type": "number",
          "minimum": 1,
          "description": "How many turns the status lasts"
        },

        "tick_damage": {
          "type": "number",
          "minimum": 0,
          "description": "Damage applied at the start or end of each turn"
        },

        "stat_modifiers": {
          "type": "object",
          "description": "Temporary stat changes applied while the status is active",
          "additionalProperties": {
            "type": "number"
          }
        },

        "control_type": {
          "type": "string",
          "enum": ["lock", "stun", "silence", "confuse"],
          "description": "Optional control effect applied by the status"
        },

        "flags": {
          "type": "object",
          "description": "Special behavior toggles for advanced status logic",
          "properties": {
            "blocks_corruption": {
              "type": "boolean",
              "description": "Prevents corruption-based effects from applying"
            },
            "reduces_damage": {
              "type": "boolean",
              "description": "Indicates the status reduces incoming damage"
            },
            "evasion_boost": {
              "type": "boolean",
              "description": "Indicates the status increases evasion"
            }
          },
          "additionalProperties": false
        },

        "description": {
          "type": "string",
          "description": "Readable description for UI"
        }
      },

      "required": [
        "id",
        "name",
        "duration",
        "tick_damage",
        "description"
      ],

      "additionalProperties": false
    }
  },

  "required": ["status"],
  "additionalProperties": false
}
