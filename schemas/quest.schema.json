{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Quest",
    "type": "object",
    "required": ["quest_code", "title", "type", "sector", "steps"],
    "properties": {
        "quest_code": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string" },
        "sector": { "type": "string" },
        "summary": { "type": "string" },
        "steps": {
            "type": "array",
            "items": { "type": "string" }
        },
        "objectives": {
            "type": "array",
            "items": { "type": "string" }
        },
        "rewards": {
            "type": "array",
            "items": { "type": "string" }
        }
    }
}
