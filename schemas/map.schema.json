{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Map",
  "type": "object",
  "required": ["id", "name", "sector", "nodes"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "sector": { "type": "string" },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type"],
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string" },
          "encounters": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
