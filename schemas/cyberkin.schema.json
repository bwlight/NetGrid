{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Cyberkin",
  "type": "object",
  "required": ["cyberkin"],
  "properties": {
    "cyberkin": {
      "type": "object",
      "required": [
        "id",
        "name",
        "family",
        "sector",
        "stage",
        "role",
        "personality",
        "element",
        "element_resistances",
        "status_resistances",
        "stats",
        "abilities",
        "evolution",
        "tags"
      ],
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "family": { "type": "string" },
        "sector": { "type": "string" },
        "stage": {
          "type": "string",
          "enum": ["Baby", "Rookie", "Champion", "Final"]
        },
        "role": {
          "type": "array",
          "items": { "type": "string" }
        },
        "personality": {
          "type": "array",
          "items": { "type": "string" }
        },
        "element": {
          "type": "string",
          "enum": [
            "core",
            "root",
            "pulse",
            "archive",
            "cloud",
            "firewall",
            "dream",
            "echo",
            "void",
            "corrupt"
          ]
        },
        "element_resistances": {
          "type": "object",
          "description": "Element → damage multiplier (0.25, 0.5, 1.0, 1.5, 2.0)",
          "patternProperties": {
            "^(core|root|pulse|archive|cloud|firewall|dream|echo|void|corrupt)$": {
              "type": "number"
            }
          },
          "additionalProperties": false
        },
        "status_resistances": {
          "type": "object",
          "description": "Status → resistance weight (-2 to +2)",
          "patternProperties": {
            "^[a-z_]+$": {
              "type": "integer",
              "minimum": -2,
              "maximum": 2
            }
          },
          "additionalProperties": false
        },
        "stats": {
          "type": "object",
          "required": ["hp", "attack", "defense", "speed", "stability"],
          "properties": {
            "hp": { "type": "integer", "minimum": 1 },
            "attack": { "type": "integer", "minimum": 0 },
            "defense": { "type": "integer", "minimum": 0 },
            "speed": { "type": "integer", "minimum": 0 },
            "stability": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "abilities": {
          "type": "object",
          "required": ["basic", "advanced", "signature"],
          "properties": {
            "basic": {
              "type": "array",
              "items": { "type": "string" }
            },
            "advanced": {
              "type": "array",
              "items": { "type": "string" }
            },
            "signature": { "type": "string" }
          },
          "additionalProperties": false
        },
        "evolution": {
          "type": "object",
          "properties": {
            "next": { "type": ["string", "null"] },
            "method": { "type": ["string", "null"] },
            "requirements": {
              "type": ["object", "null"],
              "properties": {
                "level": { "type": "integer" },
                "bond": { "type": "integer" }
              },
              "additionalProperties": false
            }
          },
          "additionalProperties": false
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
